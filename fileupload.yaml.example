# fileupload 服务配置文件
# 默认路径：当前目录下的 fileupload.yaml 或 fileupload.yml
# 也可通过 FILEUPLOAD_CONFIG 环境变量指定路径
#
# 所有配置项均可通过同名环境变量覆盖（参见 config.go loadEnv）
#
# 使用方式：
#   cp fileupload.yaml.example fileupload.yaml
#   # 修改 fileupload.yaml 中的密码、密钥等敏感信息
#   ./server

server:
  addr: ":8080"               # 监听地址
  read_timeout: 30            # 读取超时（秒）
  write_timeout: 300          # 写入超时（秒），大文件需较长超时
  idle_timeout: 60            # 空闲超时（秒）

storage:
  type: "local"               # 存储类型：local / s3
  data_dir: "storage/data"    # 数据文件存放目录
  temp_dir: "storage/tmp"     # 上传分片临时目录
  # s3:
  #   bucket: "my-bucket"
  #   region: "us-east-1"
  #   endpoint: "https://s3.amazonaws.com"
  #   prefix: "fileupload/"
  #   force_path_style: false

redis:
  addr: "localhost:6379"      # Redis 地址
  password: ""                # Redis 密码
  db: 0                       # 数据库编号
  prefix: "upload:"           # key 前缀

database:
  type: "sqlite"              # 数据库类型：sqlite / postgres
  path: "fileupload.db"       # SQLite 文件路径（仅 sqlite 模式）
  # PostgreSQL 连接配置（仅 postgres 模式，结构体形式避免 DSN 转义问题）
  # pg:
  #   host: "localhost"
  #   port: 5432
  #   user: "postgres"
  #   password: ""              # 无需 URI 转义，直接填写原始密码
  #   dbname: "fileupload"
  #   sslmode: "disable"

upload:
  session_ttl_minutes: 60     # 上传会话无活动超时（分钟）
  default_chunk_size: 10485760 # 默认分片大小（字节），10MB
  worker_pool_size: 4         # 并发 worker 池大小
  worker_queue_size: 100      # worker 排队上限

download:
  max_archive_size: 0         # 目录打包大小上限（字节，0 = 不限）

auth:
  enabled: false              # 是否启用 X-Auth-Token 静态令牌认证
  enforce: false              # JWT 强制认证（true = 无 token 请求返回 401）
  token: ""                   # 静态令牌，启用后客户端需携带此 token
  header: "X-Auth-Token"      # 令牌请求头名称
  jwt_secret: ""              # JWT 签名密钥（非空时启用 JWT 鉴权）
  jwt_expiry: 72              # JWT token 过期时间（小时）

cors:
  allowed_origins:
    - "*"                     # 允许的跨域来源，* 表示全部
