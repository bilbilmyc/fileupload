{
  "name": "fileupload-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm build:sdk && vite",
    "build": "pnpm build:sdk && tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "test": "pnpm build:sdk && vitest run",
    "test:watch": "pnpm build:sdk && vitest",
    "test:coverage": "pnpm build:sdk && vitest run --coverage",
    "test:coverage:html": "pnpm build:sdk && vitest run --coverage --coverage.reporter=html",
    "e2e": "pnpm build:sdk && playwright test",
    "e2e:install": "playwright install chromium",
    "build:sdk": "pnpm --dir ../sdk/js build"
  },
  "dependencies": {
    "@ant-design/icons": "^6.3.2",
    "@fileupload/sdk": "workspace:*",
    "antd": "^5.24.0",
    "axios": "^1.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.21",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.2.0",
    "vitest": "^4.1.9"
  }
}
